{
  "name": "sales-csm",
  "version": "1.0.0",
  "main": "dist/server.js",
  "author": "Joaqim Planstedt <mail@joaqim.xyz>",
  "license": "MIT",
  "scripts": {
    "prebuild": "tslint -c tslint.json -p tsconfig.json --fix",
    "build": "tsc --project ./",
    "dev": "nodemon ./src/server.ts --ignore ./test",
    "debug": "export DEBUG=1 && tsc && node ./dist/server.js",
    "test": "mocha -r ts-node/register 'test/**/*.test.ts'",
    "test:cursors": "mocha -r ts-node/register 'test/cursors/*.test.ts'",
    "test:fast-fail": "mocha -r ts-node/register 'test/**/*.test.ts' --bail",
    "test:debug": "export DEBUG=1 && yarn run test:fast-fail"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/chai": "^5.2.3",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.3",
    "@types/typescript": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "chai": "^6.2.2",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "ts-loader": "^9.5.4",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "bracketSpacing": true,
    "singleQuote": false,
    "trailingComma": "all",
    "printWidth": 80,
    "semi": false
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "debug": "^4.4.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-winston": "^4.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "nanoid": "^5.1.6",
    "tslint": "^6.1.3",
    "winston": "^3.19.0"
  }
}
